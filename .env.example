# Copy to .env and adjust for your machine.
# docker compose reads this file when present.

APP_NAME="Log Anomaly Detection Platform"
APP_ENV=local
NODE_ENV=development

# Ports published to the host
NGINX_PORT=80
POSTGRES_PUBLISH_PORT=5432
REDIS_PUBLISH_PORT=6379

# Internal service ports (inside Docker network)
BACKEND_INTERNAL_PORT=8000
FRONTEND_INTERNAL_PORT=3000
ML_SERVICE_INTERNAL_PORT=8001

# Postgres
POSTGRES_DB=log_anomaly
POSTGRES_USER=logwatch
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# Laravel / backend database config (used when backend is wired up)
DB_CONNECTION=pgsql

# Redis
REDIS_PORT=6379
